# Workday Authentication Configuration
# ISG User credentials (format: username@tenant)
WORKDAY_USERNAME=integration_user@your_tenant
WORKDAY_PASSWORD=your_secure_password
WORKDAY_TENANT_NAME=your_tenant_implementation

# Authentication Type: 'password' or 'certificate'
WORKDAY_AUTH_TYPE=password

# Certificate-based Authentication (optional)
# WORKDAY_CLIENT_CERT_PATH=/path/to/client_cert.pem
# WORKDAY_CLIENT_KEY_PATH=/path/to/client_key.pem

# Workday API Configuration
# Base URL for your Workday instance
WORKDAY_API_BASE_URL=https://wd2-impl-services1.workday.com

# API Version (default: v45.1)
WORKDAY_API_API_VERSION=v45.1

# Request timeout in seconds (default: 30)
WORKDAY_API_TIMEOUT=30

# Maximum retry attempts (default: 3)
WORKDAY_API_MAX_RETRIES=3

# Exponential backoff factor for retries (default: 2.0)
WORKDAY_API_RETRY_BACKOFF_FACTOR=2.0

# Application Configuration
APP_APP_NAME=Workday Procurement API
APP_APP_VERSION=1.0.0
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json
