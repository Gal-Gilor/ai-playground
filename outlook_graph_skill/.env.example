# Azure AD Application Configuration
# Copy this file to .env and fill in your actual values
# This file is automatically loaded by pydantic-settings

# ============================================================================
# REQUIRED SETTINGS
# ============================================================================

# Azure AD Application (Client) ID
AZURE_CLIENT_ID=your-application-id-here

# Azure AD Directory (Tenant) ID
AZURE_TENANT_ID=your-tenant-id-here

# Azure AD Application Client Secret
# IMPORTANT: Keep this secret secure and never commit it to version control
AZURE_CLIENT_SECRET=your-client-secret-here

# ============================================================================
# OPTIONAL SETTINGS
# ============================================================================

# Microsoft Graph API Scopes (comma-separated)
# Default: https://graph.microsoft.com/.default
GRAPH_API_SCOPES=https://graph.microsoft.com/.default

# Authentication Authority URL (auto-generated if not provided)
# AZURE_AUTHORITY=https://login.microsoftonline.com/your-tenant-id

# ============================================================================
# NESTED CONFIGURATION (using double underscore delimiter)
# ============================================================================

# API Configuration
# API__BASE_URL=https://graph.microsoft.com
# API__API_VERSION=v1.0
# API__TIMEOUT=30
# API__MAX_RETRIES=3
# API__RETRY_BACKOFF_FACTOR=2.0

# Cache Configuration
# CACHE__ENABLED=true
# CACHE__CACHE_DIR=.cache
# CACHE__CACHE_FILE_NAME=token_cache.bin

# ============================================================================
# NOTES
# ============================================================================
# - All settings are case-insensitive
# - Nested settings use double underscore (__) as delimiter
# - Boolean values: true/false, yes/no, 1/0, on/off
# - This file is automatically loaded when you instantiate SkillConfig()
# - You can override settings programmatically after loading
